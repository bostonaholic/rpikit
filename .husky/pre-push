#!/usr/bin/env bash
# Pre-push: full validation gate

set -euo pipefail

echo "Running pre-push checks..."

# 1. Full test suite
echo "  Running tests..."
./tests/run-tests.sh

# 2. Plugin validation
if command -v claude &>/dev/null; then
    echo "  Validating plugin..."
    claude plugin validate .
else
    echo "  SKIP: claude CLI not found (install via npm install -g @anthropic-ai/claude-code)"
fi

echo "Pre-push checks complete."

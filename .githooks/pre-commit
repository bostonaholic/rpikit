#!/usr/bin/env bash
# Pre-commit hook: runs the same checks as CI
# Mirrors .github/workflows/ci.yml

set -euo pipefail

echo "Running pre-commit checks..."

# 1. Lint markdown files (mirrors lint-markdown job)
if command -v markdownlint &>/dev/null; then
    echo "  Checking markdown..."
    markdownlint '**/*.md' --ignore '.beads/**/*.md'
elif command -v markdownlint-cli2 &>/dev/null; then
    echo "  Checking markdown..."
    markdownlint-cli2 '**/*.md' '!.beads/**/*.md'
else
    echo "  SKIP: markdownlint not found (install via npm install -g markdownlint-cli)"
fi

# 2. Shellcheck (mirrors shellcheck job)
if command -v shellcheck &>/dev/null; then
    echo "  Checking shell scripts..."
    shellcheck tests/*.sh bin/start
else
    echo "  SKIP: shellcheck not found (install via brew install shellcheck)"
fi

# 3. Plugin validation (mirrors validate-plugin job)
if command -v claude &>/dev/null; then
    echo "  Validating plugin..."
    claude plugin validate .
else
    echo "  SKIP: claude CLI not found (install via npm install -g @anthropic-ai/claude-code)"
fi

# 4. Test suite (mirrors test job)
echo "  Running tests..."
chmod +x tests/run-tests.sh
./tests/run-tests.sh

echo "All pre-commit checks passed."
